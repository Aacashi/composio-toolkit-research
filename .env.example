GEMINI_API_KEY=
COMPOSIO_API_KEY=
COMPOSIO_USER_ID=default
COMPOSIO_AUTH_CONFIG_ID=
# Composio dashboard Tavily toolkit version (passed to tools.execute; try without leading v if rejected)
